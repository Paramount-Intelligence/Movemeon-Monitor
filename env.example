# MoveMeOn Credentials
MOVEMEON_EMAIL=your_email@example.com
MOVEMEON_PASSWORD=your_password

# MongoDB Configuration
# Example: mongodb+srv://user:pass@cluster.mongodb.net/
MONGO_URI=mongodb://localhost:27017/

# Email Notifications (SMTP)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_alerts@gmail.com
SENDER_PASSWORD=your_app_password
RECIPIENT_EMAILS=target_email@example.com

# Monitoring Settings (daily schedule in PKT — Pakistan Standard Time, UTC+5)
DAILY_RUN_HOUR=23
DAILY_RUN_MINUTE=0
MAX_AGE_MINUTES=60
HEADLESS=True

# Platform Constants (Do not change)
PLATFORM_NAME=movemeon
PROJECTS_COLLECTION=movemeon_projects
SESSION_KEY=movemeon_cookies
MOVEMEON_DASHBOARD_URL=https://portal.movemeon.com/dashboard/candidate/jobs
MOVEMEON_JOBS_URL=https://portal.movemeon.com/dashboard/candidate/jobs
